PORT=8080
NODE_ENV=development

# PostgreSQL connection string
# - Local        : postgresql://budget:budget_secret@localhost:5432/budget_tracker?schema=public
# - Docker       : postgresql://budget:budget_secret@postgres:5432/budget_tracker?schema=public
# - Prod (Railway/Supabase/Neon) : postgresql://<user>:<password>@<host>:5432/<db>?schema=public
DATABASE_URL="postgresql://budget:budget_secret@localhost:5432/budget_tracker?schema=public"

# URL du frontend (CORS en production)
FRONTEND_URL=http://localhost:5000
