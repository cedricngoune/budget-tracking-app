# ─────────────────────────────────────────────────────────────
# Frontend — variables d'environnement (template)
# Copier ce fichier vers .env, .env.docker ou .env.production
# et ajuster les valeurs selon l'environnement cible
# ─────────────────────────────────────────────────────────────

# URL de base de l'API NestJS (sans slash final)
# - Local / Docker : laisser vide → utilise le proxy Vite ou nginx
# - Production     : https://votre-backend.railway.app/api
VITE_API_URL=
